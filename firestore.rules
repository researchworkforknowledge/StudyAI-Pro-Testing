rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default catch-all: block unauthorized operations
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure user helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint for user state update/create operations
    function isValidUserState(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && (data.board == null || (data.board is string && data.board.size() <= 64))
        && (data.cls == null || (data.cls is string && data.cls.size() <= 32))
        && (data.sub == null || (data.sub is string && data.sub.size() <= 128))
        && (data.theme == null || (data.theme is string && data.theme.size() <= 16))
        && (data.notes == null || data.notes is list)
        && (data.hw == null || data.hw is list)
        && (data.fc == null || data.fc is list)
        && (data.qt == null || data.qt is list)
        && (data.stats == null || data.stats is map);
    }

    // Validation validation for leaderboard entries
    function isValidLeaderboardEntry(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.name is string 
        && data.name.size() <= 128
        && data.xp is int
        && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 16));
    }

    // Match blocks for /users/{userId}
    match /users/{userId} {
      // Validate correct ID usage on all target modifications
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserState(request.resource.data);
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserState(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // Match blocks for shared leaderboard
    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidLeaderboardEntry(request.resource.data);
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
